(kicad_sch
  (version 20231120)
  (generator "delay_pedal_schematic")
  (paper "A4")
  (title_block
    (title "Daisy Seed Delay Pedal — Top Level")
    (rev "1.0")
    (company "")
    (comment 1 "Electrosmith Daisy Seed (STM32H750)")
  )

  ;; ── Net labels used across sheets ──────────────────────────────────────────
  ;; Power
  (global_label (at 20 20 0) (shape input) (fields_autoplaced yes)
    (property "Value" "+9V") (property "Reference" ""))
  (global_label (at 20 25 0) (shape input) (fields_autoplaced yes)
    (property "Value" "+5V") (property "Reference" ""))
  (global_label (at 20 30 0) (shape input) (fields_autoplaced yes)
    (property "Value" "+3V3") (property "Reference" ""))
  (global_label (at 20 35 0) (shape input) (fields_autoplaced yes)
    (property "Value" "GND") (property "Reference" ""))

  ;; ADC lines
  (global_label (at 20 45 0) (shape bidirectional) (fields_autoplaced yes)
    (property "Value" "ADC0_TIME") (property "Reference" ""))
  (global_label (at 20 50 0) (shape bidirectional) (fields_autoplaced yes)
    (property "Value" "ADC1_REPEATS") (property "Reference" ""))
  (global_label (at 20 55 0) (shape bidirectional) (fields_autoplaced yes)
    (property "Value" "ADC2_MIX") (property "Reference" ""))
  (global_label (at 20 60 0) (shape bidirectional) (fields_autoplaced yes)
    (property "Value" "ADC3_FILTER") (property "Reference" ""))
  (global_label (at 20 65 0) (shape bidirectional) (fields_autoplaced yes)
    (property "Value" "ADC4_GRIT") (property "Reference" ""))
  (global_label (at 20 70 0) (shape bidirectional) (fields_autoplaced yes)
    (property "Value" "ADC5_MODSPD") (property "Reference" ""))
  (global_label (at 20 75 0) (shape bidirectional) (fields_autoplaced yes)
    (property "Value" "ADC6_MODDEP") (property "Reference" ""))

  ;; GPIO lines
  (global_label (at 20 85 0) (shape bidirectional) (fields_autoplaced yes)
    (property "Value" "ENC_A") (property "Reference" ""))
  (global_label (at 20 90 0) (shape bidirectional) (fields_autoplaced yes)
    (property "Value" "ENC_B") (property "Reference" ""))
  (global_label (at 20 95 0) (shape bidirectional) (fields_autoplaced yes)
    (property "Value" "ENC_SW") (property "Reference" ""))
  (global_label (at 20 100 0) (shape bidirectional) (fields_autoplaced yes)
    (property "Value" "SW_BYPASS") (property "Reference" ""))
  (global_label (at 20 105 0) (shape bidirectional) (fields_autoplaced yes)
    (property "Value" "SW_TAP") (property "Reference" ""))
  (global_label (at 20 110 0) (shape output) (fields_autoplaced yes)
    (property "Value" "RELAY_CTL") (property "Reference" ""))
  (global_label (at 20 115 0) (shape output) (fields_autoplaced yes)
    (property "Value" "LED_BYPASS") (property "Reference" ""))
  (global_label (at 20 120 0) (shape input) (fields_autoplaced yes)
    (property "Value" "MIDI_RX") (property "Reference" ""))

  ;; ── Daisy Seed module (U1) ─────────────────────────────────────────────────
  ;; Represented as a single rectangular symbol.
  ;; Left side: power + audio. Right side: GPIO + ADC.
  (symbol
    (lib_id "daisy:DaisySeed")
    (at 100 90 0)
    (unit 1)
    (in_bom yes)
    (on_board yes)
    (uuid "daisy-u1")
    (property "Reference" "U1" (at 100 60 0))
    (property "Value" "DaisySeed" (at 100 62 0))
    (property "Footprint" "daisy:DaisySeed_Module" (at 100 64 0) (hide yes))
    (property "Datasheet" "https://electro-smith.com/daisy" (at 0 0 0) (hide yes))
  )

  ;; ── Hierarchical sheet links ───────────────────────────────────────────────
  (sheet (at 150 20 0) (size 40 20) (fields_autoplaced yes)
    (property "Sheet name" "power" (at 150 19 0))
    (property "Sheet file" "power.kicad_sch" (at 150 40 0))
  )
  (sheet (at 150 50 0) (size 40 20) (fields_autoplaced yes)
    (property "Sheet name" "pots" (at 150 49 0))
    (property "Sheet file" "pots.kicad_sch" (at 150 70 0))
  )
  (sheet (at 150 80 0) (size 40 20) (fields_autoplaced yes)
    (property "Sheet name" "controls" (at 150 79 0))
    (property "Sheet file" "controls.kicad_sch" (at 150 100 0))
  )
  (sheet (at 150 110 0) (size 40 20) (fields_autoplaced yes)
    (property "Sheet name" "io" (at 150 109 0))
    (property "Sheet file" "io.kicad_sch" (at 150 130 0))
  )
  (sheet (at 150 140 0) (size 40 20) (fields_autoplaced yes)
    (property "Sheet name" "midi" (at 150 139 0))
    (property "Sheet file" "midi.kicad_sch" (at 150 160 0))
  )
)
