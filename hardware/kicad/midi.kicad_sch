(kicad_sch
  (version 20231120)
  (generator "eeschema")
  (generator_version "7.0")
  (paper "A4")
  (lib_symbols)
  (title_block
    (title "Daisy Seed Delay Pedal — MIDI Input")
    (rev "1.0")
    (comment 1 "TRS Type-A passive MIDI input with 6N138 optocoupler isolation.")
    (comment 2 "Standard MIDI 1.0 Spec circuit. Output drives UART1 RX (D14).")
    (comment 3 "USB MIDI handled natively by Daisy USB connector (no extra components).")
  )

  ;; ── J4: TRS 3.5mm MIDI input jack (Type-A) ────────────────────────────────
  ;; Type-A: tip = MIDI source current sink (pin 5 equivalent)
  ;;         ring = MIDI source current source (pin 4 equivalent)
  (symbol (lib_id "Connector:AudioJack3") (at 30 60 0) (unit 1)
    (in_bom yes) (on_board yes) (uuid "j4")
    (property "Reference" "J4" (at 30 52 0))
    (property "Value" "MIDI_TRS_TYPE_A" (at 30 54 0))
    (property "Footprint" "Connector_Audio:Jack_3.5mm_Neutrik_NMJ3HH-S_Horizontal" (at 0 0 0) (hide yes))
  )

  ;; ── R15, R16: 220Ω current limiting resistors ─────────────────────────────
  (symbol (lib_id "Device:R") (at 60 55 0) (unit 1)
    (in_bom yes) (on_board yes) (uuid "r15")
    (property "Reference" "R15" (at 64 53 0))
    (property "Value" "220R" (at 64 55 0))
    (property "Footprint" "Resistor_THT:R_Axial_DIN0207_L6.3mm_D2.5mm_P10.16mm_Horizontal" (at 0 0 0) (hide yes))
  )
  (symbol (lib_id "Device:R") (at 60 65 0) (unit 1)
    (in_bom yes) (on_board yes) (uuid "r16")
    (property "Reference" "R16" (at 64 63 0))
    (property "Value" "220R" (at 64 65 0))
    (property "Footprint" "Resistor_THT:R_Axial_DIN0207_L6.3mm_D2.5mm_P10.16mm_Horizontal" (at 0 0 0) (hide yes))
  )

  ;; ── D3: 1N4148 protection diode (ring side, reverse polarity protection) ──
  (symbol (lib_id "Device:D") (at 80 65 0) (unit 1)
    (in_bom yes) (on_board yes) (uuid "d3")
    (property "Reference" "D3" (at 84 63 0))
    (property "Value" "1N4148" (at 84 65 0))
    (property "Footprint" "Diode_THT:D_DO-35_SOD27_P7.62mm_Horizontal" (at 0 0 0) (hide yes))
  )

  ;; ── U3: 6N138 optocoupler ─────────────────────────────────────────────────
  ;; Pin 2 = anode, Pin 3 = cathode (LED inside)
  ;; Pin 6 = output transistor collector, Pin 5 = emitter
  ;; Pin 8 = Vcc (3V3), Pin 5 = GND
  (symbol (lib_id "Isolator:6N138") (at 115 60 0) (unit 1)
    (in_bom yes) (on_board yes) (uuid "u3")
    (property "Reference" "U3" (at 115 48 0))
    (property "Value" "6N138" (at 115 50 0))
    (property "Footprint" "Package_DIP:DIP-8_W7.62mm" (at 0 0 0) (hide yes))
    (property "Datasheet" "https://www.vishay.com/docs/83622/6n138.pdf" (at 0 0 0) (hide yes))
  )

  ;; ── R17: Pull-up resistor on 6N138 output (pin 6) ─────────────────────────
  (symbol (lib_id "Device:R") (at 145 52 0) (unit 1)
    (in_bom yes) (on_board yes) (uuid "r17")
    (property "Reference" "R17" (at 149 50 0))
    (property "Value" "4.7k" (at 149 52 0))
    (property "Footprint" "Resistor_THT:R_Axial_DIN0207_L6.3mm_D2.5mm_P10.16mm_Horizontal" (at 0 0 0) (hide yes))
  )

  ;; ── C17: Bypass cap on 6N138 Vcc ──────────────────────────────────────────
  (symbol (lib_id "Device:C") (at 130 48 0) (unit 1)
    (in_bom yes) (on_board yes) (uuid "c17")
    (property "Reference" "C17" (at 134 46 0))
    (property "Value" "100nF" (at 134 48 0))
    (property "Footprint" "Capacitor_THT:C_Disc_D3.0mm_W1.6mm_P2.50mm" (at 0 0 0) (hide yes))
  )

  ;; ── Wiring ────────────────────────────────────────────────────────────────
  ;; TRS tip → R15 → opto pin 2 (anode)
  (wire (pts (xy 37 58) (xy 55 58)))
  (wire (pts (xy 55 58) (xy 55 55) (xy 65 55)))
  (wire (pts (xy 55 55) (xy 55 52) (xy 105 52)))   ;; → U3 pin2
  ;; TRS ring → R16 → D3 → opto pin 3 (cathode)
  (wire (pts (xy 37 62) (xy 55 62)))
  (wire (pts (xy 55 62) (xy 55 65) (xy 65 65)))
  (wire (pts (xy 75 65) (xy 85 65)))
  (wire (pts (xy 85 65) (xy 105 62)))               ;; → U3 pin3
  ;; TRS sleeve → GND
  (wire (pts (xy 37 65) (xy 37 90)))

  ;; 6N138 Vcc (pin 8) → 3V3
  (wire (pts (xy 125 52) (xy 125 48) (xy 130 48)))
  (wire (pts (xy 130 44) (xy 130 42)))
  (global_label (at 130 40 0) (shape input) (fields_autoplaced yes)
    (property "Value" "+3V3") (property "Reference" ""))
  ;; C17 bypass to GND
  (wire (pts (xy 130 52) (xy 130 58)))

  ;; 6N138 pin 5 (emitter) → GND
  (wire (pts (xy 125 68) (xy 125 90)))

  ;; Pull-up R17: 3V3 → R17 → 6N138 pin 6 (collector) → MIDI_RX
  (global_label (at 145 45 0) (shape input) (fields_autoplaced yes)
    (property "Value" "+3V3") (property "Reference" ""))
  (wire (pts (xy 145 47) (xy 145 50)))
  (wire (pts (xy 145 54) (xy 145 58) (xy 135 58)))  ;; R17 bottom → U3 pin6 / net junction
  (global_label (at 155 58 0) (shape output) (fields_autoplaced yes)
    (property "Value" "MIDI_RX") (property "Reference" ""))
  (wire (pts (xy 145 58) (xy 155 58)))

  ;; ── Notes ─────────────────────────────────────────────────────────────────
  (text "TRS Type-A wiring (MIDI 1.0 Spec):\n  Tip  → opto anode  (equiv DIN-5 pin 5)\n  Ring → opto cathode (equiv DIN-5 pin 4)\n  Sleeve → GND\n\nMIDI_RX connects to Daisy Seed D14 (UART1_RX)."
    (at 30 100 0) (effects (font (size 1.5 1.5))))

  (text "USB MIDI: connect Daisy USB connector directly to host.\nNo additional components required — Daisy handles USB\nMIDI device class natively via libDaisy MidiUsbHandler."
    (at 30 115 0) (effects (font (size 1.5 1.5))))

  (sheet_instances
    (path "/b0000005-0000-0000-0000-000000000005" (page "6"))
  )
)
