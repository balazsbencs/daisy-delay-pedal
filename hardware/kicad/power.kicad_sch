(kicad_sch
  (version 20231120)
  (generator "eeschema")
  (generator_version "7.0")
  (paper "A4")
  (lib_symbols)
  (title_block
    (title "Daisy Seed Delay Pedal — Power Supply")
    (rev "1.0")
    (comment 1 "9V DC → 5V LDO → Daisy Seed VIN. Daisy provides 3V3.")
    (comment 2 "MCP1700-3302 max 250mA — Daisy draws ~120mA typical.")
  )

  ;; ── J1: 2.1mm Barrel Jack (9V centre-positive) ────────────────────────────
  (symbol (lib_id "Connector:Barrel_Jack_Switch") (at 30 50 0) (unit 1)
    (in_bom yes) (on_board yes) (uuid "j1")
    (property "Reference" "J1" (at 30 44 0))
    (property "Value" "DC_9V_2.1mm" (at 30 46 0))
    (property "Footprint" "Connector_BarrelJack:BarrelJack_Vertical" (at 0 0 0) (hide yes))
  )

  ;; ── D1: Reverse-polarity protection diode ────────────────────────────────
  (symbol (lib_id "Device:D") (at 55 45 0) (unit 1)
    (in_bom yes) (on_board yes) (uuid "d1")
    (property "Reference" "D1" (at 55 41 0))
    (property "Value" "1N4001" (at 55 43 0))
    (property "Footprint" "Diode_THT:D_DO-41_SOD81_P10.16mm_Horizontal" (at 0 0 0) (hide yes))
  )

  ;; ── C1: Input bulk capacitor ─────────────────────────────────────────────
  (symbol (lib_id "Device:CP") (at 75 55 0) (unit 1)
    (in_bom yes) (on_board yes) (uuid "c1")
    (property "Reference" "C1" (at 79 53 0))
    (property "Value" "100uF/16V" (at 79 55 0))
    (property "Footprint" "Capacitor_THT:CP_Radial_D6.3mm_P2.50mm" (at 0 0 0) (hide yes))
  )

  ;; ── U2: MCP1700-3302 LDO (9V → 5V — note: use MCP1700-5002 for 5V out) ──
  ;; Using 78L05 / MCP1700-5002E for 5V output to Daisy VIN.
  (symbol (lib_id "Regulator_Linear:MCP1700-3302ET") (at 100 50 0) (unit 1)
    (in_bom yes) (on_board yes) (uuid "u2")
    (property "Reference" "U2" (at 100 43 0))
    (property "Value" "MCP1700-5002" (at 100 45 0))
    (property "Footprint" "Package_TO_SOT_THT:TO-92_Inline" (at 0 0 0) (hide yes))
    (property "Datasheet" "https://ww1.microchip.com/downloads/en/DeviceDoc/20001826D.pdf" (at 0 0 0) (hide yes))
  )

  ;; ── C2: LDO input bypass ─────────────────────────────────────────────────
  (symbol (lib_id "Device:C") (at 90 60 0) (unit 1)
    (in_bom yes) (on_board yes) (uuid "c2")
    (property "Reference" "C2" (at 94 58 0))
    (property "Value" "100nF" (at 94 60 0))
    (property "Footprint" "Capacitor_THT:C_Disc_D3.0mm_W1.6mm_P2.50mm" (at 0 0 0) (hide yes))
  )

  ;; ── C3: LDO output bypass ─────────────────────────────────────────────────
  (symbol (lib_id "Device:C") (at 120 60 0) (unit 1)
    (in_bom yes) (on_board yes) (uuid "c3")
    (property "Reference" "C3" (at 124 58 0))
    (property "Value" "100nF" (at 124 60 0))
    (property "Footprint" "Capacitor_THT:C_Disc_D3.0mm_W1.6mm_P2.50mm" (at 0 0 0) (hide yes))
  )

  ;; ── C4: Output bulk capacitor ─────────────────────────────────────────────
  (symbol (lib_id "Device:CP") (at 135 55 0) (unit 1)
    (in_bom yes) (on_board yes) (uuid "c4")
    (property "Reference" "C4" (at 139 53 0))
    (property "Value" "100uF/10V" (at 139 55 0))
    (property "Footprint" "Capacitor_THT:CP_Radial_D6.3mm_P2.50mm" (at 0 0 0) (hide yes))
  )

  ;; ── Power flags ───────────────────────────────────────────────────────────
  (global_label (at 155 50 0) (shape output) (fields_autoplaced yes)
    (property "Value" "+5V") (property "Reference" ""))
  (global_label (at 30 70 0) (shape output) (fields_autoplaced yes)
    (property "Value" "GND") (property "Reference" ""))
  (global_label (at 30 40 0) (shape output) (fields_autoplaced yes)
    (property "Value" "+9V") (property "Reference" ""))

  ;; ── Wiring ────────────────────────────────────────────────────────────────
  ;; J1 pin1 (tip/+) → D1 anode
  (wire (pts (xy 37 45) (xy 50 45)))
  ;; D1 cathode → C1+ and U2 input
  (wire (pts (xy 60 45) (xy 75 45)))
  (wire (pts (xy 75 45) (xy 95 45)))
  ;; C1- → GND
  (wire (pts (xy 75 60) (xy 75 70)))
  ;; U2 output → C3+ and +5V net
  (wire (pts (xy 110 50) (xy 120 50)))
  (wire (pts (xy 120 50) (xy 135 50)))
  (wire (pts (xy 135 50) (xy 155 50)))
  ;; C3- → GND
  (wire (pts (xy 120 60) (xy 120 70)))
  ;; C4- → GND
  (wire (pts (xy 135 60) (xy 135 70)))
  ;; J1 pin2 (sleeve/GND) → GND net
  (wire (pts (xy 37 55) (xy 37 70)))

  ;; ── Notes ─────────────────────────────────────────────────────────────────
  (text "NOTE: Daisy Seed 3V3 rail is internally regulated.\n3V3 for pots/pull-ups is taken from Daisy pin 38 (3V3).\nDo not add a separate 3V3 regulator."
    (at 30 85 0) (effects (font (size 1.5 1.5))))

  (sheet_instances
    (path "/b0000001-0000-0000-0000-000000000001" (page "2"))
  )
)
